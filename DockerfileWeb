FROM node:20-alpine AS base

FROM base AS builder
RUN apk add --no-cache libc6-compat
RUN apk update

# Set working directory
WORKDIR /app
RUN npm install -g turbo
COPY . .
RUN turbo prune --scope=@monorepo/web --docker

# Add lockfile and package.json's of isolated subworkspace
FROM base AS installer
RUN apk add --no-cache libc6-compat
RUN apk update
WORKDIR /app

# First install the dependencies (as they change less often)
COPY --from=builder /app/out/json/ .
COPY --from=builder /app/out/pnpm-lock.yaml ./pnpm-lock.yaml
COPY eslint.config.mjs ./eslint.config.mjs
RUN corepack enable
RUN pnpm install --frozen-lockfile
# Alpine (musl) + arm64/amd64: ensure sharp native binary matches the container.
RUN pnpm rebuild sharp

# Build the project
COPY --from=builder /app/out/full/ .

# 🔧 Inject build-time env vars
ARG NEXT_PUBLIC_CMS_URL
ARG NEXT_PUBLIC_URL
ARG PAYLOAD_FETCH_ALLOW_INSECURE_TLS
ENV NEXT_PUBLIC_CMS_URL=$NEXT_PUBLIC_CMS_URL
ENV NEXT_PUBLIC_URL=$NEXT_PUBLIC_URL
ENV PAYLOAD_FETCH_ALLOW_INSECURE_TLS=$PAYLOAD_FETCH_ALLOW_INSECURE_TLS

RUN pnpm dlx turbo run build --filter=@monorepo/web

FROM base AS runner
WORKDIR /app

COPY --from=installer /app/apps/web/next.config.ts . 
COPY --from=installer /app/apps/web/package.json .

# Automatically leverage output traces to reduce image size
COPY --from=installer /app/apps/web/.next/standalone ./
COPY --from=installer /app/apps/web/.next/static ./apps/web/.next/static
COPY --from=installer /app/apps/web/public ./apps/web/public

ENV PORT=3000
EXPOSE 3000

CMD node apps/web/server.js