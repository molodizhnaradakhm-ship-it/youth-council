{
  "name": "@monorepo/cms",
  "version": "0.1.0",
  "description": "A blank template to get started with Payload 3.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=--no-deprecation next build",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev --port=3001",
    "devsafe": "rm -rf .next && cross-env NODE_OPTIONS=--no-deprecation next dev",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation next lint",
    "migrate": "cross-env NODE_OPTIONS=--no-deprecation payload migrate",
    "migrate:create": "cross-env NODE_OPTIONS=--no-deprecation payload migrate:create",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start -p 3001 -H 0.0.0.0",
    "jobs": "payload jobs:run --cron \"*/5 * * * *\""
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1030.0",
    "@payloadcms/db-mongodb": "3.83.0",
    "@payloadcms/email-nodemailer": "3.83.0",
    "@payloadcms/live-preview-react": "3.83.0",
    "@payloadcms/next": "3.83.0",
    "@payloadcms/payload-cloud": "3.83.0",
    "@payloadcms/plugin-form-builder": "3.83.0",
    "@payloadcms/plugin-redirects": "3.83.0",
    "@payloadcms/plugin-search": "3.83.0",
    "@payloadcms/plugin-seo": "3.83.0",
    "@payloadcms/richtext-lexical": "3.83.0",
    "@payloadcms/storage-s3": "3.83.0",
    "@payloadcms/translations": "^3.83.0",
    "@payloadcms/ui": "3.83.0",
    "@radix-ui/react-checkbox": "^1.0.4",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-slot": "^1.0.2",
    "@types/escape-html": "^1.0.4",
    "@types/nodemailer": "^6.4.17",
    "cross-env": "^7.0.3",
    "escape-html": "^1.0.3",
    "graphql": "^16.8.1",
    "next": "15.4.11",
    "nodemailer": "^7.0.5",
    "payload": "3.83.0",
    "react": "19.2.1",
    "react-dom": "19.2.1",
    "sharp": "0.33.5",
    "slate": "^0.114.0",
    "slugify": "^1.6.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.17.0",
    "@types/node": "22.5.4",
    "@types/react": "19.2.1",
    "@types/react-dom": "19.2.1",
    "@typescript-eslint/eslint-plugin": "^8.19.0",
    "@typescript-eslint/parser": "^8.19.0",
    "eslint": "^9.16.0",
    "eslint-config-next": "15.4.8",
    "typescript": "5.7.3"
  },
  "engines": {
    "node": "^18.20.2 || >=20.9.0",
    "pnpm": "^9 || ^10"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.2.1",
      "@types/react-dom": "19.2.1"
    }
  },
  "overrides": {
    "@types/react": "19.2.1",
    "@types/react-dom": "19.2.1"
  }
}
