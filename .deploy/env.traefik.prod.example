# Domains for Traefik labels (host only, no https://)
# Base zone: ymc-org.com — adjust subdomains if you prefer other prefixes.

# Next.js marketing site (container port 3000)
WEB_YOUTH_COUNCIL_LANDING_DOMAIN=test.ymc-org.com

# Payload CMS (container port 3001)
WEB_CMS_DOMAIN=cms.ymc-org.com

# MinIO S3 API (container port 9000)
WEB_MINIO_S3_DOMAIN=s3.ymc-org.com

# MinIO web console (container port 9001)
WEB_MINIO_CONSOLE_DOMAIN=minio.ymc-org.com

# Let's Encrypt (required)
TRAEFIK_ACME_EMAIL=molodizhnaradakhm@gmail.com
