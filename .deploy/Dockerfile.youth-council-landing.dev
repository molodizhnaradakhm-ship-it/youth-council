# Dev image: Debian (glibc) — sharp prebuilds are reliable; Alpine (musl) often breaks on arm64.
FROM node:20-bookworm-slim

RUN apt-get update \
  && apt-get install -y --no-install-recommends ca-certificates \
  && rm -rf /var/lib/apt/lists/*

RUN corepack enable && corepack prepare pnpm@10.11.0 --activate

WORKDIR /app

EXPOSE 3000

ENV NEXT_TELEMETRY_DISABLED=1
# Bumped when the dev base image changes so shared node_modules volume re-syncs (e.g. sharp native binary).
ENV LANDING_DEV_RUNTIME_TAG=bookworm-slim-v1

COPY .deploy/landing-dev-entrypoint.sh /usr/local/bin/landing-dev-entrypoint.sh
RUN sed -i 's/\r$//' /usr/local/bin/landing-dev-entrypoint.sh && chmod +x /usr/local/bin/landing-dev-entrypoint.sh

# Source is bind-mounted from the repo root. Entry point installs deps once (locked),
# then executes the service command from docker-compose.
ENTRYPOINT ["sh", "/usr/local/bin/landing-dev-entrypoint.sh"]
CMD ["sh", "-lc", "pnpm --filter @monorepo/web dev:docker"]
