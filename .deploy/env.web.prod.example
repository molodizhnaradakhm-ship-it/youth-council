# Production values for `.deploy/docker-compose.prod.yml`
# Copy to `env.web.prod` on the server (`setup.sh` does this once).
# Hosts must match `env.traefik.prod` (same subdomains, HTTPS in public URLs).

# --- Next.js (build args + runtime) ---
NEXT_PUBLIC_CMS_URL=https://cms.ymc-org.com
NEXT_PUBLIC_URL=https://www.ymc-org.com
PAYLOAD_FETCH_ALLOW_INSECURE_TLS=0

# --- CMS (Payload) / Mongo ---
PAYLOAD_SECRET=change-me-use-long-random-secret
CMS_URL=https://cms.ymc-org.com
DATABASE_URI=mongodb://mongo:27017/youth-council

# --- MinIO (S3) — must match Traefik host for API (`WEB_MINIO_S3_DOMAIN`) ---
S3_BUCKET=youth-council-media
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=change-me-minio-secret
S3_ENDPOINT=https://s3.ymc-org.com
S3_REGION=us-east-1
S3_PUBLIC_URL=https://s3.ymc-org.com/youth-council-media
S3_FORCE_PATH_STYLE=true
S3_ACL=public-read

# --- MinIO server credentials (must match S3_ACCESS_KEY_ID / S3_SECRET_ACCESS_KEY if you use root user) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-minio-secret
