## Local development environment variables for `.deploy/docker-compose.dev.yml`
## Safe defaults for running locally.

# Landing Next.js (dev)
NEXT_PUBLIC_CMS_URL=http://youth-council-landing-cms:3001
NEXT_PUBLIC_URL=http://localhost:3100
PAYLOAD_FETCH_ALLOW_INSECURE_TLS=0


# CMS (Payload) / MongoDB (dev)
PAYLOAD_SECRET=dev-secret-change-me
CMS_URL=http://localhost:3101
DATABASE_URI=mongodb://mongo:27017/smarty-landing

# MinIO (S3-compatible) for Payload media uploads (dev)
S3_BUCKET=youth-council-media
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_PUBLIC_URL=http://localhost:9100/youth-council-media
S3_FORCE_PATH_STYLE=true
S3_ACL=public-read

# MinIO root credentials (dev)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

